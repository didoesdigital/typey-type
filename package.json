    "query-string": "^7.1.3",
    "react": "^18.3.1",
    "react-animate-height": "^2.0.5",
    "react-chatbot-kit": "^2.2.2",
    "react-dom": "^18.3.1",
    "react-ga4": "^2.1.0",
    "react-helmet": "^6.1.0",
